# ── Valence Diagnostics — environment template ───────────────────
# Copy to .env and fill in. NEVER commit .env to git.

# App
APP_ENV=development                   # development | production
APP_HOST=127.0.0.1
APP_PORT=8765
APP_BASE_URL=http://127.0.0.1:8765

# Security — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-to-a-long-random-string-before-launch
SESSION_COOKIE_NAME=valence_session
SESSION_MAX_AGE_SECONDS=1209600       # 14 days

# Database
# Dev default (SQLite — zero setup):
DATABASE_URL=sqlite:///./valence.db
# Production (Postgres — recommended; uncomment and set):
# DATABASE_URL=postgresql+psycopg://valence:CHANGE_ME@db:5432/valence
# DB_POOL_SIZE=10                     # base connections kept open
# DB_MAX_OVERFLOW=20                  # extra connections on burst
# DB_POOL_TIMEOUT=30                  # seconds to wait for a connection

# Uploads
MAX_UPLOAD_MB=500
UPLOAD_DIR=./uploads
RESULTS_DIR=./results

# ML weights (paths relative to project root; leave blank to fall back to pretrained)
YOLO_WEIGHTS=runs/detect/models/yolo_runs/yolov8n_bovine/weights/best.pt
CNN_WEIGHTS=models/cnn_efficientnet_b0_best.pt

# CORS (comma-separated origins; * = allow any — dev only)
CORS_ORIGINS=http://127.0.0.1:8765,http://localhost:8765

# Email (optional — for contact form relay; leave empty to only log)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@valence-diagnostics.ai
CONTACT_FORWARD_TO=hello@valence-diagnostics.ai

# Error tracking (optional)
SENTRY_DSN=
